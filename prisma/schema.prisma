generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Peserta {
  id                 Int           @id @default(autoincrement())
  nama               String
  jenisKelamin       JenisKelamin
  usia               Int
  nik                String        @unique  @default(dbgenerated("LPAD(FLOOR(RANDOM() * 10000000000000000)::TEXT, 16, '0')"))
  pendidikanTerakhir String
  jurusan            String
  tanggalLahir       DateTime      @default(now())
  tokenId            Int
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  unit               Unit          @default(UNKNOWN)
  email              String        @default("null")
  posisi             String        @default("null")
  token              Token         @relation(fields: [tokenId], references: [id])

  discScoring        DiscScoring[]
  papikostickScoring PapikostickScoring[]
  msdtScoring        MsdtScoring[]

  testSession        TestSession[]
  statusExpired      StatusExpired[]
}

model StatusExpired {
  id Int @id @default(autoincrement())
  pesertaId Int
  isExpired Boolean
  createdAt DateTime @default(now())
  expiredAt DateTime 

  peserta Peserta @relation(fields: [pesertaId], references: [id])
}

model TestSession {
  id          Int           @id @default(autoincrement())
  pesertaId   Int
  token       String
  startedAt   DateTime      @default(now())
  finishedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  statusTest  Int
  jawabanCfit JawabanCfit[]
  jawabanKraepelin JawabanKraepelin[]
  jawabanDisc JawabanDisc[]
  jawabanPapikostik JawabanPapikostik[]
  jawabanMbti JawabanMbti[]
  jawabanMsdt JawabanMsdt[]
  
  kraepelinLog KraepelinLog[]
  attempts    TestAttempt[]

  tabSwitch MovedTabLog[]
  peserta     Peserta       @relation(fields: [pesertaId], references: [id])
}

model JawabanKraepelin {
  id              Int @id @default(autoincrement())
  sessionId       Int
  columnIndex     Int
  answers         Int[]
  correctAnswers  Int
  wrongAnswers    Int
  totalAnswered   Int

  session   TestSession @relation(fields: [sessionId], references: [id])
  createdAt DateTime @default(now())

  @@index([sessionId])
}

model KraepelinLog {
  id            Int @id @default(autoincrement())
  sessionId     Int
  timestamp     DateTime
  event         String
  fromCol       Int
  toCol         Int
  fromPair      Int
  toPair        Int

  session  TestSession  @relation(fields: [sessionId], references: [id])
  createdAt DateTime @default(now())
}

model CfitQuestion {
  id         Int          @id @default(autoincrement())
  subtest    Int
  order      Int
  imagePath  String
  isPractice Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  options    CfitOption[]
}

model CfitOption {
  id         Int          @id @default(autoincrement())
  questionId Int
  label      String
  imagePath  String
  question   CfitQuestion @relation(fields: [questionId], references: [id])

  @@index([questionId])
}

model DiscQuestion {
  id            Int @id @default(autoincrement())
  questionIndex Int

  option DiscOption[]
}

model DiscOption {
  id          Int @id @default(autoincrement())
  questionId  Int
  sentences   String
  optionIndex Int

  disc DiscQuestion @relation(fields: [questionId], references: [id])
}

model PapikostickQuestion {
  id            Int @id @default(autoincrement())
  questionIndex Int
  
  option PapikostickOption[]
}

model PapikostickOption {
  id          Int @id @default(autoincrement())
  questionId  Int
  sentences   String
  optionType  Int

  papikostick PapikostickQuestion @relation(fields: [questionId], references: [id])
}

model MsdtQuestion {
  id            Int @id @default(autoincrement())
  questionIndex Int

  option MsdtOption[]
}

model MsdtOption{
  id          Int @id @default(autoincrement())
  questionId  Int
  sentences   String
  optionType  Int

  msdt MsdtQuestion @relation(fields: [questionId], references: [id])
}


model mbtiQuestion {
  id              Int @id @default(autoincrement())
  question        String
  questionIndex   Int

  options mbtiOption[]
}

model mbtiOption {
  id          Int @id @default(autoincrement())
  questionId  Int
  sentences   String
  optionType  Int

  mbti mbtiQuestion @relation(fields: [questionId], references: [id])
}



model Token {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  role      Role      @default(ADMIN)
  kuota     Int
  usedCount Int       @default(0)
  isActive  Boolean   @default(true)
  activeDate DateTime @default(now())
  expiredDate DateTime @default(now())
  createdAt DateTime  @default(now())
  expiredAt DateTime?
  tests     Tests[]
  peserta   Peserta[]
}

model TestAttempt {
  id         Int              @id @default(autoincrement())
  sessionId  Int
  testType   String
  startedAt  DateTime         @default(now())
  finishedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  answers    JawabanPeserta[]
  session    TestSession      @relation(fields: [sessionId], references: [id])
}

model JawabanPeserta {
  id         Int         @id @default(autoincrement())
  attemptId  Int
  questionId Int
  answer     Json
  createdAt  DateTime    @default(now())
  attempt    TestAttempt @relation(fields: [attemptId], references: [id])
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      Role  @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JawabanCfit {
  id         Int         @id @default(autoincrement())
  sessionId  Int
  subtest    Int
  questionId Int
  createdAt  DateTime    @default(now())
  answers    String[]
  session    TestSession @relation(fields: [sessionId], references: [id])
}

model JawabanDisc {
  id            Int @id @default(autoincrement())
  sessionId     Int
  questionIndex Int
  most          Int
  least         Int

  session       TestSession @relation(fields: [sessionId], references: [id])
}

model JawabanPapikostik {
  id              Int @id @default(autoincrement())
  sessionId       Int
  questionIndex   Int
  type            Int

  session TestSession @relation(fields: [sessionId], references: [id])
}

model JawabanMbti {
  id              Int @id @default(autoincrement())
  sessionId       Int
  questionIndex   Int
  type            Int

  session TestSession @relation(fields: [sessionId], references: [id])
}

model JawabanMsdt {
  id Int @id @default(autoincrement())
  sessionId Int
  questionIndex Int
  type Int

  session TestSession @relation(fields: [sessionId], references: [id])
}

model MovedTabLog {
  id Int @id @default(autoincrement())
  sessionId Int
  eventsType String
  timeStamp DateTime

  session TestSession @relation(fields: [sessionId], references: [id])
}

model PapikostickScoring {
  id Int @id @default(autoincrement())
  pesertaId Int
  createdAt DateTime @default(now())
  statusSent Int 

  sub1  String @default("NULL")
  sub2  String @default("NULL")
  sub3  String @default("NULL")
  sub4  String @default("NULL")
  sub5  String @default("NULL")
  sub6  String @default("NULL")
  sub7  String @default("NULL")
  sub8  String @default("NULL")
  sub9  String @default("NULL")
  sub10 String @default("NULL")
  sub11 String @default("NULL")
  sub12 String @default("NULL")
  sub13 String @default("NULL")
  sub14 String @default("NULL")
  sub15 String @default("NULL")
  sub16 String @default("NULL")
  sub17 String @default("NULL")
  sub18 String @default("NULL")
  sub19 String @default("NULL")
  sub20 String @default("NULL")

  peserta Peserta @relation(fields: [pesertaId], references: [id])
}

model DiscScoring {
  id Int @id @default(autoincrement())
  pesertaId Int
  createdAt DateTime @default(now())
  statusSent Int 

  maskType                String @default("NULL")
  maskCharacteristics     String @default("NULL")
  coreType                String @default("NULL")
  coreCharacteristics     String @default("NULL")
  mirrorType              String @default("NULL")
  mirrorCharacteristics   String @default("NULL")
  personalityDescription  String @default("NULL")
  jobMatch                String @default("NULL")

  peserta                 Peserta @relation(fields: [pesertaId], references: [id])
}

model MsdtScoring {
  id Int @id @default(autoincrement())
  pesertaId Int
  statusSent Int

  hasilTest String
  status String
  mainExplanation1 String
  mainExplanation2 String
  description String

  peserta Peserta @relation(fields: [pesertaId], references: [id])
}

model Testing {
  id Int @id @default(autoincrement())
  pesertaId Int
  row_number Int
  kesimpulan String
}

enum JenisKelamin {
  LAKI_LAKI
  PEREMPUAN
}

enum Tests {
  CFIT
  DISC
  MSDT
  MBTI
  KRAEPELIN
  PAPIKOSTICK
}

enum Unit {
  SMP
  MPP
  MMPP
  IMP
  PPH
  ACS
  UNKNOWN
}

enum Role {
  ADMIN
  SMP
  MPP
  MMPP
  IMP
  PPH
  ACS
}
